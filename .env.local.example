# ─────────────────────────────────────────────────────────────────────────────
# ROYALTY NAILS & SPA — Environment Variables
#
# 1. Copy this file to .env.local  →  cp .env.local.example .env.local
# 2. Fill in your Supabase values  →  https://supabase.com/dashboard
# 3. Never commit .env.local to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API

# Public URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (safe to expose to the browser — row-level security protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SERVER ONLY — never expose to the browser)
# Used by API routes to bypass Row Level Security for trusted operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
