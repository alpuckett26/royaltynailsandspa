# ─────────────────────────────────────────────────────────────────────────────
# ROYALTY NAILS & SPA — Environment Variables
#
# 1. Copy this file to .env.local  →  cp .env.local.example .env.local
# 2. Fill in your Supabase values  →  https://supabase.com/dashboard
# 3. Never commit .env.local to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API

# Public URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (safe to expose to the browser — row-level security protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SERVER ONLY — never expose to the browser)
# Used by API routes to bypass Row Level Security for trusted operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create API Key
# Free tier: 100 emails/day, 3,000/month — no credit card needed
RESEND_API_KEY=re_your_api_key_here

# The "From" address for outgoing emails.
# Must be a domain you have verified in Resend → Domains.
# Until you verify a domain, use: onboarding@resend.dev (test mode, sends to verified email only)
RESEND_FROM_EMAIL=Royalty Nails & Spa <bookings@royaltynailsandspa.com>

# Your site's public URL — used to build calendar links in customer emails.
NEXT_PUBLIC_SITE_URL=https://royaltynailsandspa.com

# ── Cron Security ─────────────────────────────────────────────────────────────
# Random secret that protects the /api/cron/daily-reminder endpoint.
# Generate one with:  openssl rand -hex 32
# Set this same value in Vercel → Settings → Environment Variables.
CRON_SECRET=your-random-secret-here

# ── Square Payments ───────────────────────────────────────────────────────────
# Get credentials from: developer.squareup.com → your app → Credentials tab
# Toggle between Sandbox and Production in that tab.

# Set to "sandbox" for testing, "production" when live
SQUARE_ENV=sandbox
NEXT_PUBLIC_SQUARE_ENV=sandbox

# Application ID (safe to expose — used by Square Web Payments SDK in browser)
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-your-app-id

# Location ID (safe to expose)
SQUARE_LOCATION_ID=your-location-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-location-id

# Access Token (SERVER ONLY — never expose to browser)
SQUARE_ACCESS_TOKEN=your-access-token

# Deposit amount in cents (2500 = $25.00)
DEPOSIT_AMOUNT_CENTS=2500

# Shown to customers on the booking page (should match DEPOSIT_AMOUNT_CENTS / 100)
NEXT_PUBLIC_DEPOSIT_AMOUNT=25
